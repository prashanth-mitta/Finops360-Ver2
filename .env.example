# FinOps 360 - frontend environment variables (Create React App)
# Copy this file to ".env" and fill in your Supabase project values.
# Find these under: Supabase Dashboard > Project Settings > API

REACT_APP_SUPABASE_URL=https://jbyrcixklqbaznerhoyh.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# NOTE: Only the anon (public) key belongs in the frontend. The anon key is safe
# to expose because all access is gated by Postgres Row-Level Security.
# NEVER put the service_role key in this file or any frontend code.
